NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
INVITE_CODE_SALT=
IMPORT_TOKEN=change-this-local-import-token
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=
GOOGLE_MAPS_SERVER_KEY=
# Per explicit Maps/enrichment script run cap (Text Search + Place Details). Default 500 if unset.
# Bulk scripts resolve:locations and enrich:places share this cap per run.
GOOGLE_MAPS_MAX_REQUESTS=500
# Alias for GOOGLE_MAPS_MAX_REQUESTS
IMPORT_GEOCODE_MAX=
# Force-skip Google Maps calls in code paths that support geocoding.
IMPORT_SKIP_GEOCODE=false
NEXT_PUBLIC_APP_URL=http://localhost:3000
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_FALLBACK_MODEL=llama3.2:3b
OLLAMA_NUM_CTX=8192
EXTRACT_USE_OLLAMA=true
EXTRACT_MAX_OLLAMA_THREADS=
EXTRACT_RUN_ID=
